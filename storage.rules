rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Publicly readable
      allow read: if true;
      
      // Only admin can write
      allow write: if request.auth != null && 
                   (request.auth.token.email in ["tareatharva@gmail.com", "shantanujagirdar@gmail.com"]);
    }
  }
}